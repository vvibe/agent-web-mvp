# Server port (WebSocket + HTTP)
PORT=8787

# Default working directory for new sessions (must exist).
# Frontend can override per-session. Pick a path that suits your OS, e.g.
#   macOS / Linux: /Users/you/code        or   /home/you/code
#   Windows:       C:\Users\you\code
DEFAULT_CWD=

# Anthropic API key — required by the Claude Agent SDK unless you're already
# logged in via `claude` CLI. If unset, the SDK will use whatever auth the
# bundled `claude` CLI has stored.
# ANTHROPIC_API_KEY=sk-ant-...

# Server-side opt-in for Codex sessions. Without this, the server refuses
# every create_session for agent='codex' (codex has no per-tool permission
# UI yet — its sandbox/approval flags via daemon's CODEX_ARGS are the
# entire security model, so both server and daemon must consciously opt
# in). The daemon-side counterpart is configured with `vvibe codex enable`.
# CODEX_TRUST_DEFAULTS=1

# Bind only to localhost by default. Set to 0.0.0.0 ONLY if you're tunnelling
# this through Tailscale / Cloudflare Tunnel and understand the security risk.
HOST=127.0.0.1

# Shared secret the Go daemon must present on the /client WebSocket. Leave
# empty for the single-user dev MVP (any client accepted).
# CLIENT_TOKEN=changeme

# GitHub OAuth credentials. Leave unset to keep the server in anonymous
# dev mode (everyone is the synthetic `anon` user, sessions run on the
# dev server itself rather than going through a paired daemon).
#
# Set both to enable real per-user accounts + daemon pairing. Create the
# OAuth App at https://github.com/settings/developers with:
#   Homepage URL:        http://127.0.0.1:8787
#   Authorization URL:   http://127.0.0.1:8787/auth/github/callback
# See README "Local dev modes" for the full setup.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Externally-visible base URL. Defaults to http://127.0.0.1:${PORT}.
# Override when running behind a reverse proxy / tunnel so OAuth callback
# URLs and Origin allowlists line up.
# PUBLIC_URL=http://127.0.0.1:8787
